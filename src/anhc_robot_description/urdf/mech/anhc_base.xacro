<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ═══════════════════════════════════════════════════════════
       ANHC BASE MECHANICAL DESCRIPTION
       Defines: chassis, 4 wheels, caster (base_footprint → base_link)
       Coordinate convention: X=forward, Y=left, Z=up
       ═══════════════════════════════════════════════════════════ -->

  <!-- ── Tunable Parameters ─────────────────────────────────── -->
  <xacro:property name="base_length"    value="0.50"/>   <!-- meters -->
  <xacro:property name="base_width"     value="0.35"/>
  <xacro:property name="base_height"    value="0.15"/>
  <xacro:property name="base_mass"      value="10.0"/>   <!-- kg     -->

  <xacro:property name="wheel_radius"   value="0.075"/>
  <xacro:property name="wheel_width"    value="0.05"/>
  <xacro:property name="wheel_mass"     value="0.5"/>

  <!-- Wheel X offset from center (front/rear) -->
  <xacro:property name="wheel_x_offset" value="0.175"/>
  <!-- Wheel Y offset from center (left/right) -->
  <xacro:property name="wheel_y_offset" value="0.200"/>
  <!-- Wheel Z = radius (sits on ground) minus half base height -->
  <xacro:property name="wheel_z_offset" value="0.0"/>

  <!-- ── Inertia Macros ──────────────────────────────────────── -->
  <!-- Box inertia (chassis) -->
  <xacro:macro name="box_inertia" params="m l w h">
    <inertial>
      <mass value="${m}"/>
      <inertia
        ixx="${(m/12.0)*(w*w + h*h)}"  ixy="0" ixz="0"
        iyy="${(m/12.0)*(l*l + h*h)}"  iyz="0"
        izz="${(m/12.0)*(l*l + w*w)}"/>
    </inertial>
  </xacro:macro>

  <!-- Cylinder inertia (wheels) -->
  <xacro:macro name="cylinder_inertia" params="m r h">
    <inertial>
      <mass value="${m}"/>
      <inertia
        ixx="${(m/12.0)*(3*r*r + h*h)}"  ixy="0" ixz="0"
        iyy="${(m/12.0)*(3*r*r + h*h)}"  iyz="0"
        izz="${(m/2.0)*r*r}"/>
    </inertial>
  </xacro:macro>

  <!-- ── Wheel Macro ─────────────────────────────────────────── -->
  <!--
    Creates one wheel link + joint.
    Parameters:
      prefix  : fl | fr | rl | rr
      x_sign  : +1 (front) | -1 (rear)
      y_sign  : +1 (left)  | -1 (right)
  -->
  <xacro:macro name="anhc_wheel" params="prefix x_sign y_sign">

    <!-- Link -->
    <link name="anhc_${prefix}_wheel_link">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="anhc_wheel_material">
          <color rgba="0.1 0.1 0.1 1.0"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <xacro:cylinder_inertia m="${wheel_mass}" r="${wheel_radius}" h="${wheel_width}"/>
    </link>

    <!-- Continuous Joint (wheel spins freely around Y axis) -->
    <joint name="anhc_${prefix}_wheel_joint" type="continuous">
      <parent link="anhc_base_link"/>
      <child  link="anhc_${prefix}_wheel_link"/>
      <origin
        xyz="${x_sign * wheel_x_offset}
             ${y_sign * wheel_y_offset}
             ${wheel_z_offset}"
        rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="0.1" friction="0.1"/>
      <limit effort="10.0" velocity="5.0"/>
    </joint>

  </xacro:macro>

  <!-- ══════════════════════════════════════════════════════════
       LINKS
       ══════════════════════════════════════════════════════════ -->

  <!-- base_footprint: virtual link at ground level, origin of the robot -->
  <link name="base_footprint"/>

  <!-- base_link: geometric center of chassis, elevated above ground -->
  <link name="anhc_base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="anhc_chassis_material">
        <color rgba="0.2 0.5 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="${base_mass}" l="${base_length}" w="${base_width}" h="${base_height}"/>
  </link>

  <!-- ══════════════════════════════════════════════════════════
       JOINTS
       ══════════════════════════════════════════════════════════ -->

  <!-- base_footprint → base_link: lift chassis off the ground by wheel_radius -->
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="anhc_base_link"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>

  <!-- ── Instantiate 4 Wheels ────────────────────────────────── -->
  <!-- Front-Left  --> <xacro:anhc_wheel prefix="fl" x_sign=" 1" y_sign=" 1"/>
  <!-- Front-Right --> <xacro:anhc_wheel prefix="fr" x_sign=" 1" y_sign="-1"/>
  <!-- Rear-Left   --> <xacro:anhc_wheel prefix="rl" x_sign="-1" y_sign=" 1"/>
  <!-- Rear-Right  --> <xacro:anhc_wheel prefix="rr" x_sign="-1" y_sign="-1"/>

</robot>
