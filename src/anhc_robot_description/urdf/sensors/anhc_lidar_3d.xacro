<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="anhc_lidar_3d" params="parent_link xyz rpy">

    <link name="anhc_lidar_3d_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><cylinder radius="0.04" length="0.07"/></geometry>
        <material name="anhc_lidar_material">
          <color rgba="0.8 0.1 0.1 1.0"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><cylinder radius="0.04" length="0.07"/></geometry>
      </collision>
      <inertial>
        <mass value="0.1"/>
        <inertia ixx="0.001" ixy="0" ixz="0"
                 iyy="0.001" iyz="0" izz="0.001"/>
      </inertial>
    </link>

    <joint name="anhc_lidar_3d_joint" type="fixed">
      <parent link="${parent_link}"/>
      <child  link="anhc_lidar_3d_link"/>
      <origin xyz="${xyz}" rpy="${rpy}"/>
    </joint>

    <gazebo reference="anhc_lidar_3d_link">
      <sensor name="anhc_lidar_3d_sensor" type="gpu_lidar">
        <topic>/anhc/lidar_3d/points</topic>
        <update_rate>10</update_rate>
        <always_on>true</always_on>
        <visualize>false</visualize>
        <!-- frame_id: use ignition/gz convention -->
        <frame_id>anhc_lidar_3d_link</frame_id>
        <lidar>
          <scan>
            <horizontal>
              <samples>360</samples>
              <resolution>1</resolution>
              <min_angle>-3.14159</min_angle>
              <max_angle>3.14159</max_angle>
            </horizontal>
            <vertical>
              <samples>16</samples>
              <resolution>1</resolution>
              <min_angle>-0.26180</min_angle>
              <max_angle>0.26180</max_angle>
            </vertical>
          </scan>
          <range>
            <min>0.1</min>
            <max>100.0</max>
            <resolution>0.01</resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.01</stddev>
          </noise>
        </lidar>
      </sensor>
    </gazebo>

  </xacro:macro>
</robot>
