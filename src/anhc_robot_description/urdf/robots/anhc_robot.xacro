<?xml version="1.0"?>
<robot name="anhc_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ═══════════════════════════════════════════════════════════
       ANHC ROBOT ASSEMBLER
       Includes all subsystems and places sensors on the chassis.
       ═══════════════════════════════════════════════════════════ -->

  <!-- ── Include subsystem xacros ────────────────────────────── -->
  <xacro:include filename="$(find anhc_robot_description)/urdf/mech/anhc_base.xacro"/>
  <xacro:include filename="$(find anhc_robot_description)/urdf/sensors/anhc_lidar_3d.xacro"/>
  <xacro:include filename="$(find anhc_robot_description)/urdf/sensors/anhc_lidar_2d.xacro"/>
  <xacro:include filename="$(find anhc_robot_description)/urdf/sensors/anhc_camera.xacro"/>
  <xacro:include filename="$(find anhc_robot_description)/urdf/control/anhc_control.xacro"/>

  <!-- ── Material Definitions ────────────────────────────────── -->
  <material name="anhc_chassis_material"> <color rgba="0.2 0.5 0.8 1.0"/> </material>
  <material name="anhc_wheel_material">   <color rgba="0.1 0.1 0.1 1.0"/> </material>
  <material name="anhc_lidar_material">   <color rgba="0.8 0.1 0.1 1.0"/> </material>
  <material name="anhc_lidar2d_material"> <color rgba="0.1 0.8 0.1 1.0"/> </material>
  <material name="anhc_camera_material">  <color rgba="0.1 0.1 0.1 1.0"/> </material>

  <!-- ── Instantiate Mechanical Base ─────────────────────────── -->
  <!-- (base.xacro defines base_footprint, anhc_base_link, 4 wheels) -->

  <!-- ── Place 3D LiDAR on top-center of chassis ─────────────── -->
  <!--
    base_height/2 = 0.075  → top surface of chassis
    lidar cylinder height/2 = 0.035
    Total z = 0.075 + 0.035 = 0.110
  -->
  <xacro:anhc_lidar_3d
    parent_link="anhc_base_link"
    xyz="0.0 0.0 0.110"
    rpy="0 0 0"/>

  <!-- ── Place 2D LiDAR at front of chassis ───────────────────── -->
  <!--
    x = base_length/2 = 0.25 (front edge)
    z = base_height/2 + lidar_box_height/2 = 0.075 + 0.02 = 0.095
  -->
  <xacro:anhc_lidar_2d
    parent_link="anhc_base_link"
    xyz="0.20 0.0 0.095"
    rpy="0 0 0"/>

  <!-- ── Place RGB Camera at front, slightly raised ────────────── -->
  <!--
    x = 0.225 (just at front edge)
    z = 0.10 (above chassis top)
    pitch = 0 (looking straight forward)
  -->
  <xacro:anhc_camera
    parent_link="anhc_base_link"
    xyz="0.225 0.0 0.10"
    rpy="0 0 0"/>

  <!-- ── Instantiate ros2_control + Gazebo plugins ────────────── -->
  <xacro:anhc_control/>

  <!-- ── IMU Link (for TF completeness) ──────────────────────── -->
  <link name="anhc_imu_link">
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.0001" ixy="0" ixz="0"
               iyy="0.0001" iyz="0"
               izz="0.0001"/>
    </inertial>
  </link>
  <joint name="anhc_imu_joint" type="fixed">
    <parent link="anhc_base_link"/>
    <child  link="anhc_imu_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ── Gazebo Physics Properties ────────────────────────────── -->
  <gazebo reference="anhc_base_link">
    <mu1>0.8</mu1>
    <mu2>0.8</mu2>
    <kp>1e6</kp>
    <kd>1.0</kd>
    <material>Gazebo/Blue</material>
  </gazebo>

  <gazebo reference="anhc_fl_wheel_link">
    <mu1>1.0</mu1><mu2>1.0</mu2><kp>1e6</kp><kd>1.0</kd>
    <material>Gazebo/Black</material>
  </gazebo>
  <gazebo reference="anhc_fr_wheel_link">
    <mu1>1.0</mu1><mu2>1.0</mu2><kp>1e6</kp><kd>1.0</kd>
    <material>Gazebo/Black</material>
  </gazebo>
  <gazebo reference="anhc_rl_wheel_link">
    <mu1>1.0</mu1><mu2>1.0</mu2><kp>1e6</kp><kd>1.0</kd>
    <material>Gazebo/Black</material>
  </gazebo>
  <gazebo reference="anhc_rr_wheel_link">
    <mu1>1.0</mu1><mu2>1.0</mu2><kp>1e6</kp><kd>1.0</kd>
    <material>Gazebo/Black</material>
  </gazebo>

</robot>
